// GoGlobal Image Service — OpenAI version (frontend)

const CACHE_PREFIX = "gg_img_v1_";

function cacheKey(prompt) {
  let hash = 0;
  for (let i = 0; i < prompt.length; i++) {
    hash = ((hash << 5) - hash + prompt.charCodeAt(i)) | 0;
  }
  return CACHE_PREFIX + Math.abs(hash).toString(36);
}

export async function generateImage(prompt) {
  if (!prompt) return null;

  const apiKey = import.meta.env.VITE_OPENAI_API_KEY;
  if (!apiKey) {
    console.error("[ImageService] Missing OpenAI API key");
    return null;
  }

  const key = cacheKey(prompt);

  // ✅ Session cache
  try {
    const cached = sessionStorage.getItem(key);
    if (cached) return cached;
  } catch (_) {}

  try {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 15000);

    const res = await fetch("https://api.openai.com/v1/images/generations", {
      method: "POST",
      signal: controller.signal,
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: "gpt-image-1",
        prompt: enhancePrompt(prompt),
        size: "1024x1024",
      }),
    });

    clearTimeout(timeout);

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      console.error("[ImageService] OpenAI error:", err);
      return null;
    }

    const data = await res.json();
    const url = data?.data?.[0]?.url;

    if (!url) {
      console.error("[ImageService] No image returned");
      return null;
    }

    // cache result
    try {
      sessionStorage.setItem(key, url);
    } catch (_) {}

    return url;

  } catch (err) {
    if (err.name === "AbortError") {
      console.error("[ImageService] Request timed out");
    } else {
      console.error("[ImageService] Network error:", err);
    }
    return null;
  }
}

function enhancePrompt(base) {
  return `${base}, ultra realistic, cinematic lighting, high detail, professional photography, 4k, natural colors`;
}